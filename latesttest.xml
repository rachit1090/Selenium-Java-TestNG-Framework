<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Latest"
	parallel="tests"
	thread-count="3"
>


		<listeners>
			<listener class-name="utility.Listeners"></listener>
			<listener class-name="utility.RetryTransformer"></listener>
		</listeners>

  <test name="ChromeTest">
  	 <parameter name="browser" value="chrome"></parameter>
  		<parameter name="headless" value="true"></parameter>
  		<!-- <groups>
  			<run>
  				<include name="verifyNewFeature"/>
  			</run>
  		</groups> -->
    <classes>
      <class name="tests.RegressionTest">
      </class>
    </classes>
  </test> <!-- Test -->
  
  <test name="EdgeTest">
  	 <parameter name="browser" value="edge"></parameter>
  		<parameter name="headless" value="true"></parameter>
  	<!--	<groups>
  			<run>
  				<include name="verifyNewFeature"/>
  			</run>
  		</groups> -->
    <classes>
      <class name="tests.RegressionTest">
      </class>
    </classes>
  </test> <!-- Test -->
  
  
</suite> <!-- Latest -->
